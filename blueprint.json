{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "full_name": { "type": "string" },
        "avatar_url": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "diretor", "secretario"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "role", "status"]
    },
    "Student": {
      "title": "Student",
      "description": "Student information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "registration_number": { "type": "string" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "rg": { "type": "string" },
        "birth_date": { "type": "string" },
        "start_date": { "type": "string" },
        "status": { "type": "string" },
        "is_former_student": { "type": "boolean" },
        "class_id": { "type": "string" },
        "address_street": { "type": "string" },
        "address_neighborhood": { "type": "string" },
        "address_city": { "type": "string" },
        "address_state": { "type": "string" },
        "address_zip": { "type": "string" },
        "parish": { "type": "string" },
        "forania": { "type": "string" },
        "course": { "type": "string" },
        "pastoral_participates": { "type": "string" },
        "phone_mobile": { "type": "string" },
        "phone_mobile_is_whatsapp": { "type": "boolean" },
        "phone_residential": { "type": "string" },
        "phone_commercial": { "type": "string" },
        "email": { "type": "string" },
        "guardian_father": { "type": "string" },
        "guardian_mother": { "type": "string" },
        "guardian_cpf": { "type": "string" },
        "photo_url": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "user_id": { "type": "string" }
      },
      "required": ["id", "registration_number", "name", "status"]
    },
    "Class": {
      "title": "Class",
      "description": "School class information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "room": { "type": "string" },
        "status": { "type": "string", "enum": ["Ativo", "Inativo"] },
        "period": { "type": "string", "enum": ["Manhã", "Tarde", "Noite"] },
        "days_of_week": { "type": "array", "items": { "type": "string" } },
        "semester": { "type": "string" },
        "start_date": { "type": "string", "format": "date" },
        "observations": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "name", "status", "period"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Course subject information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "program_content": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "name"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Teacher information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "phone_mobile": { "type": "string" },
        "cpf": { "type": "string" },
        "rg": { "type": "string" },
        "address_street": { "type": "string" },
        "address_city": { "type": "string" },
        "address_state": { "type": "string" },
        "address_zip": { "type": "string" },
        "birth_date": { "type": "string" },
        "observations": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "name", "email"]
    },
    "PixTransaction": {
      "title": "PixTransaction",
      "description": "PIX payment transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "payer_name": { "type": "string" },
        "origin_bank": { "type": "string" },
        "amount": { "type": "number" },
        "transaction_id": { "type": "string" },
        "batch_id": { "type": "string" },
        "status": { "type": "string", "enum": ["matched", "unmatched", "multiple"] },
        "matched_student_id": { "type": "string" },
        "is_manual": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "payer_name", "amount", "transaction_id", "status"]
    },
    "Contribution": {
      "title": "Contribution",
      "description": "Student contribution/payment record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "student_id": { "type": "string" },
        "amount": { "type": "number" },
        "reference_month": { "type": "number" },
        "reference_year": { "type": "number" },
        "payment_date": { "type": "string" },
        "payment_method": { "type": "string", "enum": ["PIX", "Cartão", "Dinheiro"] },
        "origin": { "type": "string" },
        "pix_id": { "type": "string" },
        "observations": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "student_id", "amount", "reference_month", "reference_year", "payment_date"]
    },
    "InstitutionSettings": {
      "title": "InstitutionSettings",
      "description": "General settings for the institution",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "logo_url": { "type": "string" },
        "footer_text": { "type": "string" },
        "receipt_message": { "type": "string" },
        "secretary": { "type": "string" },
        "cep": { "type": "string" },
        "city_uf": { "type": "string" },
        "subtitle": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "Foraria": {
      "title": "Foraria",
      "description": "Diocese Foraria",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "priest_name": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "name"]
    },
    "ClergyLeity": {
      "title": "ClergyLeity",
      "description": "Diocese Clergy and Leity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "address_neighborhood": { "type": "string" },
        "address_city": { "type": "string" },
        "address_state": { "type": "string" },
        "phone_mobile": { "type": "string" },
        "phone_whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "parish_id": { "type": "string" },
        "role": { "type": "string", "enum": ["pároco", "vigário", "diácono", "seminarista", "leigo formado"] },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "name", "role", "user_id"]
    },
    "EmailRegistry": {
      "title": "EmailRegistry",
      "description": "Pre-registered emails for authentication",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "registered_at": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Parish": {
      "title": "Parish",
      "description": "Church Parish information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "forania_id": { "type": "string" },
        "priest_id": { "type": "string" },
        "priest_name": { "type": "string" },
        "address_street": { "type": "string" },
        "address_number": { "type": "string" },
        "address_neighborhood": { "type": "string" },
        "address_city": { "type": "string" },
        "address_state": { "type": "string" },
        "address_zip": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "name"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "Academic calendar event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["holiday", "exam", "start_term", "end_term", "class_day", "event"] },
        "class_id": { "type": "string" },
        "subject_id": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "start_date", "type"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Student attendance record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "student_id": { "type": "string" },
        "class_id": { "type": "string" },
        "subject_id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["P", "F", "J"] },
        "observations": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "student_id", "class_id", "date", "status"]
    },
    "Grade": {
      "title": "Grade",
      "description": "Student subject grade",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "student_id": { "type": "string" },
        "class_id": { "type": "string" },
        "subject_id": { "type": "string" },
        "period": { "type": "string" },
        "value": { "type": "number" },
        "status": { "type": "string", "enum": ["Aprovado", "Reprovado", "Recuperação"] },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "student_id", "class_id", "subject_id", "value"]
    },
    "AcademicParameters": {
      "title": "AcademicParameters",
      "description": "Global academic configuration parameters",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "approval_grade": { "type": "number" },
        "recovery_grade": { "type": "number" },
        "failure_grade": { "type": "number" },
        "absence_limit_percentage": { "type": "number" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["approval_grade", "recovery_grade", "failure_grade", "absence_limit_percentage"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Academic certificate or diploma",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "student_id": { "type": "string" },
        "type": { "type": "string", "enum": ["conclusão", "participação", "honra"] },
        "issuance_date": { "type": "string", "format": "date" },
        "course": { "type": "string" },
        "verification_code": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "student_id", "type", "issuance_date"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Student enrollment in a class",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "student_id": { "type": "string" },
        "class_id": { "type": "string" },
        "status": { "type": "string", "enum": ["Ativo", "Concluído", "Trancado", "Cancelado"] },
        "enrollment_date": { "type": "string", "format": "date" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "student_id", "class_id", "status"]
    }
  },
  "firestore": {
    "users": { "schema": "UserProfile", "description": "User profile collection" },
    "students": { "schema": "Student", "description": "Student records collection" },
    "classes": { "schema": "Class", "description": "School classes collection" },
    "subjects": { "schema": "Subject", "description": "Course subjects collection" },
    "teachers": { "schema": "Teacher", "description": "Teachers collection" },
    "pix_reconciliations": { "schema": "PixTransaction", "description": "PIX transactions collection" },
    "contributions": { "schema": "Contribution", "description": "Contributions collection" },
    "institution_settings": { "schema": "InstitutionSettings", "description": "Institution configuration" },
    "email_registry": { "schema": "EmailRegistry", "description": "Email registry for pre-auth" },
    "foraries": { "schema": "Foraria", "description": "Foraries collection" },
    "parishes": { "schema": "Parish", "description": "Parishes collection" },
    "clergy_leity": { "schema": "ClergyLeity", "description": "Clergy and Leity collection" },
    "calendar_events": { "schema": "CalendarEvent", "description": "Academic calendar events" },
    "attendances": { "schema": "Attendance", "description": "Attendance tracking" },
    "grades": { "schema": "Grade", "description": "Student grades" },
    "academic_parameters": { "schema": "AcademicParameters", "description": "Global academic parameters" },
    "certificates": { "schema": "Certificate", "description": "Issued certificates and diplomas" },
    "enrollments": { "schema": "Enrollment", "description": "Student enrollments in classes" },
    "archived_students": { "schema": "Student", "description": "Archived student records" },
    "archived_teachers": { "schema": "Teacher", "description": "Archived teacher records" },
    "archived_classes": { "schema": "Class", "description": "Archived class records" },
    "archived_subjects": { "schema": "Subject", "description": "Archived subject records" }
  }
}

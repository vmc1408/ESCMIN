rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserRole() == role;
    }
    
    function isAdmin() { 
      return isRole('admin') || (isSignedIn() && (request.auth.token.email == 'alves@alves.com' || request.auth.token.email == 'vmcjobnow@gmail.com')); 
    }
    
    function isDirector() { 
      return isAdmin() || isRole('diretor');
    }
    
    function isStaff() { 
      return isAdmin() || (isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (getUserRole() in ['admin', 'diretor', 'secretario'])
      )); 
    }

    // Users & Roles
    match /users/{userId} {
      // Get: allow anyone signed in to get their own (and for login checks)
      // but strictly restrict list to the requested logic
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        isAdmin() || 
        (isRole('diretor') && (resource.data.role == 'secretario' || userId == request.auth.uid)) ||
        (userId == request.auth.uid)
      );
      
      // Basic profile creation for self or by director
      // Note: we use isDirector() here which includes admin
      allow create: if isSignedIn() && (request.auth.uid == userId || isDirector());
      
      // Update: admin can update anyone. Director can update self and secretaries. Secretary update self.
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isRole('diretor') && (resource.data.role == 'secretario' || userId == request.auth.uid)) ||
        (userId == request.auth.uid)
      );
      
      // Allow delete if admin OR if director is removing a secretary OR if the user is cleaning up their own record
      allow delete: if isAdmin() || (isRole('diretor') && resource.data.role == 'secretario') || (isSignedIn() && (userId == request.auth.uid || userId == request.auth.token.email));
    }

    match /email_registry/{email} {
      allow read: if isDirector(); // Only directors and admins (via isDirector helper) can see the registry
      allow write: if isDirector();
    }

    match /students/{studentId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /classes/{classId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /teachers/{teacherId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /subjects/{subjectId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /pix_reconciliations/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /contributions/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /institution_settings/{id} {
      allow read: if true;
      allow write: if isDirector();
    }

    match /foraries/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /parishes/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /clergy_leity/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }
  }
}

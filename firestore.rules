rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() == role;
    }
    function isAdmin() { return isRole('admin'); }
    function isDirector() { 
      return isAdmin() || isRole('diretor') || (isSignedIn() && request.auth.token.email == 'alves@alves.com');
    }
    function isStaff() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserRole() in ['admin', 'diretor', 'secretario']); 
    }

    // Users & Roles
    match /users/{userId} {
      // Allow single document lookup for pre-registration check and profile fetching
      allow get: if true;
      allow list: if isSignedIn();
      
      // Basic profile creation for self or by director
      allow create: if isSignedIn() && (request.auth.uid == userId || isDirector());
      
      // Update: self can update some fields, director can update everything
      allow update: if isSignedIn() && (
        request.auth.uid == userId || isDirector()
      );
      
      // Allow delete if director OR if the user is cleaning up their own pre-registration record
      allow delete: if isDirector() || (isSignedIn() && (userId == request.auth.uid || userId == request.auth.token.email));
    }

    match /email_registry/{email} {
      allow read: if isStaff();
      allow write: if isDirector();
    }

    match /students/{studentId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /classes/{classId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /teachers/{teacherId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /subjects/{subjectId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /pix_reconciliations/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /contributions/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /institution_settings/{id} {
      allow read: if true;
      allow write: if isDirector();
    }

    match /foraries/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /parishes/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }
  }
}

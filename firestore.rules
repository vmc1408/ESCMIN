rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() { return isSignedIn() && getUserRole() == 'admin'; }
    function isDirector() { return isSignedIn() && (getUserRole() == 'admin' || getUserRole() == 'diretor'); }
    function isStaff() { return isSignedIn() && (getUserRole() in ['admin', 'diretor', 'secretario']); }

    // Users & Roles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /classes/{classId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /teachers/{teacherId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /subjects/{subjectId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /pix_reconciliations/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /contributions/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /institution_settings/{id} {
      allow read: if true;
      allow write: if isDirector();
    }

    match /foraries/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /parishes/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }
  }
}
